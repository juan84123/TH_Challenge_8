<h1>Nuevo tema</h1>

<div style="border: 1px solid #ddd; border-radius: 8px; padding: 16px;">
  <form action="/topics" method="POST">

    <label>Título</label>
    <input type="text" name="title" placeholder="Ej: Cómo programar como un ninja" required>

    <label>Descripción</label>
    <textarea name="description" rows="4" placeholder="¿De qué trata este tema?" required></textarea>

    <div style="display: flex; gap: 12px; margin-top: 8px;">
      <button type="submit" class="btn btn-primary">Crear tema</button>
      <a href="/" class="btn btn-secondary">Cancelar</a>
    </div>

  </form>
</div>